{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    { "src": "api/rates.py",   "use": "@vercel/python" },
    { "src": "api/data.py",    "use": "@vercel/python" },
    { "src": "api/refresh.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/rates",   "dest": "api/rates.py"   },
    { "src": "/api/data",    "dest": "api/data.py"    },
    { "src": "/api/refresh", "dest": "api/refresh.py" },
    { "src": "/(.*)",        "dest": "dashboard/$1"   }
  ]
}
